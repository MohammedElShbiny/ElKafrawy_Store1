# MongoDB Configuration
# This is the connection string for your MongoDB database (e.g., MongoDB Atlas).
# It should start with mongodb:// or mongodb+srv://
# If not set, the app will use a local file-based fallback.
MONGODB_URI=mongodb://localhost:27017/elkafrawy_db

# Application URL
# The URL where your frontend application is deployed
VITE_APP_URL=https://elkafrawy-test.netlify.app/
